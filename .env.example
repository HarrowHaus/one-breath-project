# .env.example — copy this to a file named ".env" and fill in real values.
# NEVER commit the real .env. It is already in .gitignore.
# For Cloudflare, these same values are entered in the Pages dashboard as
# environment variables (Claude Code will tell you where in each phase).

# --- Database (Phase 2: Neon or Supabase Postgres + PostGIS) ---
DATABASE_URL=

# --- Admin screen (Phase 2: password for manual data entry) ---
ADMIN_PASSWORD=

# --- EPA AirNow (Phase 2: free key, outdoor/contextual data only) ---
AIRNOW_API_KEY=

# --- Connector ingestion (Phase 2B: bearer token a scheduler uses to trigger
#     POST /api/admin/ingest/<source>). Generate a long random string. ---
INGEST_TOKEN=

# --- Analytics (Phase 10: privacy-first, e.g. Plausible/Fathom) ---
ANALYTICS_SITE_ID=

# --- Maps (Phase 8: only if using Mapbox; MapLibre needs no key) ---
MAPBOX_TOKEN=

# Notes:
# - CDC Tracking, CPSC NEISS, and CDC WONDER APIs generally need no key.
# - Leave anything you're not using blank.
