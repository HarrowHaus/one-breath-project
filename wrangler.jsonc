{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "one-breath-project",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-04-01",
  // nodejs_compat gives us the Node.js APIs the OpenNext adapter (and the
  // Phase 2 Postgres-backed internal API) rely on.
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  }
}
